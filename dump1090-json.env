DUMP1090_HOST=adsbexchange           # Host serving tar1090 (must resolve from Docker, or use extra_hosts in compose)
DUMP1090_HTTP_PORT=80              # HTTP port for aircraft.json
JSON_PATH=/tar1090/data/aircraft.json
GROUND_LEVEL=65                    # WGS84 ground reference; match TRIPOD_ALTITUDE in .env

# Values for testing
CONTINUE_ON_EXCEPTION=False
LOG_LEVEL=DEBUG
