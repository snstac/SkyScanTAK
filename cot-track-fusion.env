# CoT / TAK receive + ledger merge (see cot/track_fusion/README.md)
# Uses the same **`COT_URL`** as **`cot-bridge`** (loaded from `cot-bridge.env` via compose).
# Set **`COT_RX_URL`** here only if RX must differ from send (overrides **`COT_URL`**).
# COT_RX_URL=

# Last-seen TTL for CoT rows not refreshed (seconds)
# COT_TRACK_TTL_SECONDS=30

# JSON list of [fnmatch_pattern, priority] — higher wins. Default in code favors a-*-A-M-H-Q.
# SKYSCAN_COT_PRIORITY_RULES=[["a-*-A-M-H-Q", 1000], ["a-f-A-C*", 50]]

# ADS-B rows get this skyscan_priority (C2 sorts higher first)
# ADS_B_PRIORITY=0
