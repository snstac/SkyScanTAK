# --- CoT destination (PyTAK) ---
# TAK Server enrollment (resolves to tls://takserver… and caches client cert under ~/.pytak/certs).
# Security: enrollment tokens are secrets—avoid committing this file or rotate the token if it was exposed.
# Docker: map a volume to /root/.pytak so enrollment is not repeated on every container recreate.
# Set COT_URL locally (do not commit enrollment tokens). Example:
# COT_URL=tak://com.atakmap.app/enroll?host=takserver.example.com&username=myuser&token=YOUR_TOKEN
# Legacy UDP fallback when COT_URL is unset (ignored while COT_URL is set):
COT_UDP_HOST=172.17.2.20
COT_UDP_PORT=24242
# COT_MULTICAST_TTL=32

# Stable CoT identity (must not change between restarts for TAK track continuity)
COT_UID=SKYSCAN-roof_sf-CAM1
COT_CALLSIGN=SkyScan Roof CAM

# Event timing
COT_STALE_SECONDS=120
COT_HEARTBEAT_INTERVAL=8

# Periodic marker-style ping (separate uid); set COT_PING_INTERVAL=0 to disable
COT_PING_INTERVAL=0
COT_PING_STALE_SECONDS=60
COT_PING_TYPE=b-m-p-s-m
# COT_PING_UID defaults to "<COT_UID>-ping" if unset

# Periodic friendly equipment / EO sensor (2525-style event type); 0 = disable
COT_EQUIP_INTERVAL=60
COT_EQUIP_TYPE=a-f-G-E-S-E

# Point uncertainty (meters)
POINT_CE=15.0
POINT_LE=10.0

# Horizontal / vertical field of view (degrees); used at zoom endpoints below
SENSOR_FOV_H=55.0
SENSOR_FOV_V=32.0
# Linear zoom interpolation: FOV at Axis zoom 0 (wide) and 9999 (tele). Default: both = SENSOR_FOV_* (static FOV).
# SENSOR_FOV_H_WIDE=60
# SENSOR_FOV_H_TELE=12
# SENSOR_FOV_V_WIDE=36
# SENSOR_FOV_V_TELE=8
# MITRE <sensor type="..."> modality (raster EO zoom continuous); not the same as mapping event SENSOR_TYPE
SENSOR_MODALITY_TYPE=r-e-z-c
SENSOR_TYPE=b-m-p-s-p-e
SENSOR_MODEL=AXIS Q6215-LE
# Optional <sensor> extras (omit if unset): roll/north in degrees per CoT Sensor Schema
# SENSOR_ROLL=0
# SENSOR_NORTH=0

# Max CoT sends per second when Logger messages are streaming (limits UDP load)
COT_MAX_SEND_RATE=5.0

# PTZ pose: emit BOTH by default so WinTAK (mapping <sensor>) and TAK/TAKX (u-d-f FOV polygon) can each use what they support.
COT_SENSOR_ENABLE=true
COT_FOV_ENABLE=true

# Aircraft track from skyscan-c2 OBJECT_TOPIC -> CoT mapping marker (MITRE b-m-p-s-p-i = sensor point of interest).
# Uses same PyTAK destination as PTZ CoT. Set COT_AIR_ENABLE=false to disable.
# COT_AIR_TYPE=b-m-p-s-p-i
# Alternative spot-map style: COT_AIR_TYPE=b-m-p-s-m
# COT_AIR_STALE_SECONDS=45
# COT_AIR_MAX_SEND_RATE=3.0
# COT_AIR_POINT_CE=15
# COT_AIR_POINT_LE=10
# COT_AIR_HOW=m-g
# COT_AIR_UID_PREFIX=
# COT_AIR_LINK_SENSOR=true

# Second CoT at same position: spot-map POI for “what SkyScan is tracking” (default b-m-p-s-m).
# Distinct uid (SPI base + suffix); same rate limit as aircraft SPI. Disable with COT_TRACK_POI_ENABLE=false.
COT_TRACK_POI_ENABLE=true
# COT_TRACK_POI_TYPE=b-m-p-s-m
# COT_TRACK_POI_HOW=h-g-i-g-o
# COT_TRACK_POI_UID_SUFFIX=-poi
# COT_TRACK_POI_STALE_SECONDS=
# COT_TRACK_POI_COLOR_ARGB=-65536
# COT_TRACK_POI_ICONSET=COT_MAPPING_SPOTMAP/b-m-p-s-m/-65536

# Ground FOV polygon (TAK/TAKX drawing; paired with COT_SENSOR_ENABLE above).
# Second CoT with stable COT_FOV_UID, same PyTAK destination as PTZ; emitted on the same cadence as the mapping sensor.
# COT_FOV_FORMAT=tak
# Alt: COT_FOV_FORMAT=mitre for <detail><shape><polyline closed="true"><vertex.../></polyline></shape>
# COT_FOV_DEFAULT_RANGE_M=10000
# COT_FOV_STALE_SECONDS=
# COT_FOV_UID=
# COT_FOV_HOW=h-e
# COT_FOV_NEAR_MIN_M=10
# COT_FOV_NEAR_FRAC=0.01
# COT_FOV_MIN_GROUND_M=50
# COT_FOV_POINT_CE_MARGIN=50
# COT_FOV_CALLSIGN=SkyScan FOV
# COT_FOV_FILL_COLOR=-1761607681
# COT_FOV_STROKE_COLOR=-1
# COT_FOV_STROKE_WEIGHT=3.0
