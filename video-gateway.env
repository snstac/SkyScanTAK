# SkyScan video-gateway: Axis RTSP → MediaMTX (RTSP or SRT). Raw passthrough + HUD overlay transcode (see flags below).

# Master switch
VIDEO_ENABLE=true

# Raw: camera H.264 copy (`-c:v copy`) to MEDIAMTX. HUD: drawtext + libx264 to separate path (video-only RTSP leg).
# Set VIDEO_KLV_ENABLE=true for a third path `…_cam_hud_klv` (ST0601). ATAK TCP optional (VIDEO_ATAK_TS_TCP_*).
VIDEO_RAW_ENABLE=true
VIDEO_HUD_ENABLE=true

# Legacy alias (optional): VIDEO_FIRIS_ENABLE — if set, used only when VIDEO_HUD_ENABLE is unset.

# If unset, built as rtsp://CAMERA_USER:CAMERA_PASSWORD@CAMERA_IP/axis-media/media.amp?videocodec=h264
# CAMERA_RTSP_URL=rtsp://root:pass@192.168.1.50/axis-media/media.amp?videocodec=h264

# MediaMTX — see video/MEDIAMTX_SNSTAK.md and video/README.md
#
# Prefer secrets in gitignored `.env` (compose loads video-gateway.env then .env; later wins).
#
# --- Publish protocol (stream.snstak.com: RTSP publish on 8554 matches other camera relays) ---
# `rtsp` — FFmpeg publishes with `-f rtsp -rtsp_transport tcp` to rtsp://USER:PASS@HOST:PORT/PATH
# `srt`  — MPEG-TS over SRT on MEDIAMTX_SRT_PORT (legacy; uses streamid publish form)
MEDIAMTX_PUBLISH_PROTOCOL=rtsp
MEDIAMTX_RTSP_PORT=8554

# Option A — full URL (quote the whole line so `#` is not a comment):
# RTSP (when MEDIAMTX_PUBLISH_PROTOCOL=rtsp):
# MEDIAMTX_RTSP_URL_HUD="rtsp://SkyScanTAK:PASS@stream.snstak.com:8554/your_stream"
# SRT (when MEDIAMTX_PUBLISH_PROTOCOL=srt):
# MEDIAMTX_SRT_URL_HUD="srt://stream.snstak.com:8890?streamid=#!::m=publish,r=your_stream,u=USER,s=PASS&pkt_size=1316"
#
# Option B — leave full URLs empty and set host + credentials; entrypoint builds publish URLs.
#
# Three MediaMTX paths (when enabled): raw copy, HUD video-only, HUD+KLV (only when VIDEO_KLV_ENABLE=true).
# Defaults when DEPLOYMENT is set and path vars are unset:
#   MEDIAMTX_PUBLISH_PATH_* → skyscan_${DEPLOYMENT}_cam_raw | _cam_hud | _cam_hud_klv
# Breaking: clients that consumed KLV on the old single HUD path must use ..._cam_hud_klv (HUD leg is video-only).
#
# MEDIAMTX_PUBLISH_PATH_HUD — HUD overlay transcode, video only (no KLV PID).
# MEDIAMTX_PUBLISH_PATH_HUD_KLV — same HUD H.264 plus ST0601 KLV data stream (when KLV on).
# MEDIAMTX_PUBLISH_PATH_RAW — camera H.264 copy (-c:v copy) when VIDEO_RAW_ENABLE=true.
MEDIAMTX_RTSP_URL_HUD=
MEDIAMTX_SRT_URL_HUD=
MEDIAMTX_PUBLIC_HOST=stream.snstak.com
MEDIAMTX_SRT_PORT=8890
MEDIAMTX_PUBLISH_USER=SkyScanTAK
MEDIAMTX_PUBLISH_PASS=CHANGEME
# MEDIAMTX_PUBLISH_PATH_HUD=skyscan_roof_sf_cam_hud
# MEDIAMTX_PUBLISH_PATH_HUD_KLV=skyscan_roof_sf_cam_hud_klv

# Full URL overrides (optional; quote whole line). HUD+KLV leg — only used when VIDEO_KLV_ENABLE=true:
# MEDIAMTX_RTSP_URL_HUD_KLV="rtsp://SkyScanTAK:PASS@stream.snstak.com:8554/your_stream_hud_klv"
# MEDIAMTX_SRT_URL_HUD_KLV="srt://stream.snstak.com:8890?streamid=#!::m=publish,r=your_stream_hud_klv,u=USER,s=PASS&pkt_size=1316"
MEDIAMTX_RTSP_URL_HUD_KLV=
MEDIAMTX_SRT_URL_HUD_KLV=

# Raw passthrough — only published when VIDEO_RAW_ENABLE=true:
# MEDIAMTX_RTSP_URL_RAW="rtsp://SkyScanTAK:PASS@stream.snstak.com:8554/your_stream_raw"
# MEDIAMTX_SRT_URL_RAW="srt://stream.snstak.com:8890?streamid=#!::m=publish,r=your_stream_raw,u=USER,s=PASS&pkt_size=1316"
MEDIAMTX_RTSP_URL_RAW=
MEDIAMTX_SRT_URL_RAW=
# MEDIAMTX_PUBLISH_PATH_RAW=skyscan_roof_sf_cam_raw

# MQTT-driven HUD text file + optional KLV FIFO for FFmpeg. Legacy SmartCam KLV reference: ../../CTI/sc3d/smartcam_stream.py
VIDEO_HUD_PATH=/tmp/skyscan_hud.txt
VIDEO_KLV_FIFO=/tmp/skyscan_klv.fifo
VIDEO_KLV_ENABLE=false
VIDEO_KLV_RATE=10
# VIDEO_MISSION_ID= optional; defaults to DEPLOYMENT

# Encoder (HUD / overlay transcode)
VIDEO_BITRATE=4M
VIDEO_PRESET=veryfast
VIDEO_TUNE=zerolatency
VIDEO_GOP=30
VIDEO_FONTFILE=/usr/share/fonts/truetype/dejavu/DejaVuSansMono-Bold.ttf
VIDEO_HUD_FONTSIZE=26
# HUD look — tuned to FIRIS-style wildfire / FMV stills (phosphor green, no box).
# Reference imagery: KDRV / KRCR FIRIS screen grabs (neon green, red ARMED alerts on aircraft builds).
# VIDEO_HUD_FONTCOLOR=#39FF14
# VIDEO_HUD_BOX=0
# VIDEO_HUD_BOXCOLOR=black@0.42
# VIDEO_HUD_BOXBORDERW=12
# VIDEO_HUD_LINE_SPACING=4
# VIDEO_HUD_BORDERW=1
# VIDEO_HUD_X=24
# VIDEO_HUD_Y=20
# VIDEO_HUD_SHADOWX=0
# VIDEO_HUD_SHADOWY=0
# VIDEO_HUD_SHADOWCOLOR=black@0.75
VIDEO_FFMPEG_LOGLEVEL=warning
# When ffmpeg exits (network blip, mux error), restart after this many seconds (container also has restart: unless-stopped)
VIDEO_FFMPEG_RESTART=true
# VIDEO_FFMPEG_RESTART_DELAY_SEC=5
# Haivision / ISR: Baseline often required for decode (black video if High/Main)
VIDEO_X264_PROFILE=baseline
# RTSP decode buffer (helps "Thread message queue blocking"); try 8192 on busy hosts
# VIDEO_RTSP_THREAD_QUEUE=4096

# --- ATAK / UAS (full MPEG-TS with KLV; bypasses MediaMTX metadata drop) ---
# Listens on VIDEO_ATAK_TS_TCP_PORT; clients use ffmpeg/VLC-style: tcp://video-gateway-host:8556
# Android ATAK often needs VPN/LAN to this host; map port 8556 in compose / firewall.
VIDEO_ATAK_TS_TCP_ENABLE=false
VIDEO_ATAK_TS_TCP_PORT=8556
# CAMERA_*, SENSOR_FOV_* loaded from compose env_file (.env)
