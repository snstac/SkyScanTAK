# SkyScan video-gateway: Axis RTSP → MediaMTX (SRT MPEG-TS), HUD on H.264 (+ optional ST0601 KLV)

# Master switch
VIDEO_ENABLE=true

# HUD pipeline (primary): decode → drawtext overlay → libx264 → SRT. Raw passthrough off by default — set VIDEO_RAW_ENABLE=true to re-enable.
VIDEO_RAW_ENABLE=false
VIDEO_HUD_ENABLE=true

# Legacy alias (optional): VIDEO_FIRIS_ENABLE — if set, used only when VIDEO_HUD_ENABLE is unset.

# If unset, built as rtsp://CAMERA_USER:CAMERA_PASSWORD@CAMERA_IP/axis-media/media.amp?videocodec=h264
# CAMERA_RTSP_URL=rtsp://root:pass@192.168.1.50/axis-media/media.amp?videocodec=h264

# MediaMTX SRT (port srtAddress :8890). Remote publish requires credentials.
#
# Custom URL streamid=publish:path does NOT send user/pass → "authentication failed"
# from non-loopback IPs when internal auth requires it.
#
# Use the standard stream ID form (quote the whole URL so '#' is not treated as comment):
#   https://mediamtx.org/docs/features/srt-specific-features
#
# r= must match a path you configure in MediaMTX (publish + read permissions). Legacy env: MEDIAMTX_SRT_URL_FIRIS.
#
# Optional duplicate passthrough (same camera, second SRT path). Leave empty when VIDEO_RAW_ENABLE=false.
# MEDIAMTX_SRT_URL_RAW="srt://stream.snstak.com:8890?streamid=#!::m=publish,r=live/skyscan_roof_sf_cam_raw,u=SkyScanTAK,s=SkyScanTAK1234&pkt_size=1316"
MEDIAMTX_SRT_URL_RAW=

MEDIAMTX_SRT_URL_HUD="srt://stream.snstak.com:8890?streamid=#!::m=publish,r=live/skyscan_roof_sf_cam_hud,u=SkyScanTAK,s=SkyScanTAK1234&pkt_size=1316"

# MQTT-driven HUD text file + optional KLV FIFO for FFmpeg. Legacy SmartCam KLV reference: ../../CTI/sc3d/smartcam_stream.py
VIDEO_HUD_PATH=/tmp/skyscan_hud.txt
VIDEO_KLV_FIFO=/tmp/skyscan_klv.fifo
VIDEO_KLV_ENABLE=true
VIDEO_KLV_RATE=10
# VIDEO_MISSION_ID= optional; defaults to DEPLOYMENT

# Encoder (HUD / overlay transcode)
VIDEO_BITRATE=4M
VIDEO_PRESET=veryfast
VIDEO_TUNE=zerolatency
VIDEO_GOP=30
VIDEO_FONTFILE=/usr/share/fonts/truetype/dejavu/DejaVuSansMono-Bold.ttf
VIDEO_HUD_FONTSIZE=26
# HUD look — tuned to FIRIS-style wildfire / FMV stills (phosphor green, no box).
# Reference imagery: KDRV / KRCR FIRIS screen grabs (neon green, red ARMED alerts on aircraft builds).
# VIDEO_HUD_FONTCOLOR=#39FF14
# VIDEO_HUD_BOX=0
# VIDEO_HUD_BOXCOLOR=black@0.42
# VIDEO_HUD_BOXBORDERW=12
# VIDEO_HUD_LINE_SPACING=4
# VIDEO_HUD_BORDERW=1
# VIDEO_HUD_X=24
# VIDEO_HUD_Y=20
# VIDEO_HUD_SHADOWX=0
# VIDEO_HUD_SHADOWY=0
# VIDEO_HUD_SHADOWCOLOR=black@0.75
VIDEO_FFMPEG_LOGLEVEL=warning
# When ffmpeg exits (network blip, mux error), restart after this many seconds (container also has restart: unless-stopped)
# VIDEO_FFMPEG_RESTART=true
# VIDEO_FFMPEG_RESTART_DELAY_SEC=5
# Haivision / ISR: Baseline often required for decode (black video if High/Main)
VIDEO_X264_PROFILE=baseline
# RTSP decode buffer (helps "Thread message queue blocking"); try 8192 on busy hosts
# VIDEO_RTSP_THREAD_QUEUE=4096

# --- ATAK / UAS (full MPEG-TS with KLV; bypasses MediaMTX metadata drop) ---
# Listens on VIDEO_ATAK_TS_TCP_PORT; clients use ffmpeg/VLC-style: tcp://video-gateway-host:8556
# Android ATAK often needs VPN/LAN to this host; map port 8556 in compose / firewall.
VIDEO_ATAK_TS_TCP_ENABLE=true
VIDEO_ATAK_TS_TCP_PORT=8556
# CAMERA_*, SENSOR_FOV_* loaded from compose env_file (.env)
